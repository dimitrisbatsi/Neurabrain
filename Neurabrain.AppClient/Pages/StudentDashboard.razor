@page "/student-dashboard"
@using System.Security.Claims
@using Neurabrain.Shared.DTOs
@attribute [Authorize(Roles = "Student")]
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<PageTitle>Το Γραφείο μου - Dyskover</PageTitle>

<div class="container mt-4 mb-5">
    <div class="row mb-4 align-items-center bg-white p-4 rounded-4 shadow-sm border-bottom border-4 @GetLevelBorderColor()">
        <div class="col-md-7">
            <h1 class="fw-bold text-primary mb-1">
                <i class="bi bi-emoji-smile me-2 text-warning"></i> Γεια σου, @firstName!
            </h1>
            <p class="text-muted fs-5 mb-0">Καλώς ήρθες στον προσωπικό σου χώρο ανακαλύψεων.</p>
        </div>
        <div class="col-md-5 text-md-end mt-3 mt-md-0">
            <div class="d-flex justify-content-md-end align-items-center gap-3">

                <div class="text-center px-3 border-end">
                    <div class="fs-6 text-muted mb-1">Αποστολές</div>
                    <div class="fs-4 fw-bold text-dark"><i class="bi bi-check-circle-fill text-success me-1"></i> @stats.CompletedMissions</div>
                </div>

                <div class="text-center px-3 border-end">
                    <div class="fs-6 text-muted mb-1">Σκορ</div>
                    <div class="fs-4 fw-bold text-dark"><i class="bi bi-star-fill text-warning me-1"></i> @stats.TotalScore</div>
                </div>

                <div class="text-center px-2">
                    <div class="badge @GetLevelBadgeColor() p-3 rounded-4 shadow-sm fs-6 d-flex align-items-center flex-column gap-1">
                        <i class="@GetLevelIcon() fs-4"></i>
                        <span>@GetLevelName()</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <h5 class="mt-3 text-muted">Φορτώνουμε τις αποστολές σου...</h5>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        </div>
    }
    else
    {
        <h3 class="fw-bold mb-4 pb-2">
            <i class="bi bi-list-task me-2 text-primary"></i> Οι Αποστολές μου (@assignments.Count)
        </h3>

        <div class="row g-4">
            @if (assignments == null || !assignments.Any())
            {
                <div class="col-12">
                    <div class="card bg-light border-0 shadow-sm rounded-4 text-center py-5">
                        <div class="card-body">
                            <i class="bi bi-trophy text-warning" style="font-size: 4rem;"></i>
                            <h3 class="mt-3 fw-bold text-success">Συγχαρητήρια!</h3>
                            <p class="fs-5 text-muted">Έχεις ολοκληρώσει όλες τις εργασίες σου. Ώρα για παιχνίδι!</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @foreach (var assignment in assignments)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition" style="border-top: 5px solid #0d6efd !important;">
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                                        <i class="bi bi-easel2 me-1"></i> @assignment.ClassroomName
                                    </span>
                                </div>
                                <h4 class="card-title fw-bold mt-2">@assignment.Title</h4>

                                <div class="mt-auto pt-3">
                                    @if (assignment.DueDate.HasValue)
                                    {
                                        <div class="text-danger small mb-2 fw-bold">
                                            <i class="bi bi-clock-history me-1"></i> Λήγει: @assignment.DueDate.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                    <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm"
                                            @onclick="() => StartExercise(assignment.AssignmentId)">
                                        <i class="bi bi-play-fill me-1"></i> Ξεκίνα!
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    /* Custom Colors for Ranks */
    .bg-bronze {
        background-color: #cd7f32;
        color: white;
    }

    .bg-silver {
        background-color: #c0c0c0;
        color: #333;
    }

    .bg-gold {
        background-color: #ffd700;
        color: #333;
    }
</style>

@code {
    private List<StudentAssignmentDto> assignments = new();
    private StudentStatsDto stats = new();

    private bool isLoading = true;
    private string? errorMessage;
    private string firstName = "Μαθητή";

    protected override async Task OnInitializedAsync()
    {
        await ExtractUserFirstName();
        await LoadData();
    }

    private async Task ExtractUserFirstName()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            var fullName = user.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value;
            if (!string.IsNullOrEmpty(fullName))
            {
                firstName = fullName.Split(' ')[0];
            }
        }
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            // Παράλληλο φόρτωμα και των 2 APIs για ταχύτητα!
            var assignmentsTask = Http.GetFromJsonAsync<List<StudentAssignmentDto>>("api/studentdashboard/my-assignments");
            var statsTask = Http.GetFromJsonAsync<StudentStatsDto>("api/studentdashboard/my-stats");

            await Task.WhenAll(assignmentsTask, statsTask);

            if (assignmentsTask.Result != null) assignments = assignmentsTask.Result;
            if (statsTask.Result != null) stats = statsTask.Result;
        }
        catch (Exception)
        {
            errorMessage = "Αποτυχία φόρτωσης δεδομένων. Δοκίμασε ξανά σε λίγο.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartExercise(Guid assignmentId)
    {
        NavManager.NavigateTo($"/play/{assignmentId}");
    }

    // --- GAMIFICATION LOGIC ---

    private string GetLevelName()
    {
        if (stats.TotalScore < 10) return "Χάλκινος Εξερευνητής";
        if (stats.TotalScore < 30) return "Ασημένιο Ξεφτέρι";
        return "Χρυσός Κυρίαρχος";
    }

    private string GetLevelBadgeColor()
    {
        if (stats.TotalScore < 10) return "bg-bronze";
        if (stats.TotalScore < 30) return "bg-silver";
        return "bg-gold";
    }

    private string GetLevelIcon()
    {
        if (stats.TotalScore < 10) return "bi-compass"; // Εξερευνητής
        if (stats.TotalScore < 30) return "bi-lightning-charge-fill"; // Ξεφτέρι
        return "bi-trophy-fill"; // Κυρίαρχος
    }

    private string GetLevelBorderColor()
    {
        if (stats.TotalScore < 10) return "border-danger"; // Μια χάλκινη αίσθηση
        if (stats.TotalScore < 30) return "border-secondary";
        return "border-warning";
    }
}