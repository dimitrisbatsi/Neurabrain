@page "/admin/learning-conditions"
@attribute [Authorize(Roles = "SuperAdmin, Admin")]
@using Neurabrain.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Μαθησιακές Δυσκολίες & AI Prompts</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Διαχείριση Μαθησιακών Δυσκολιών & AI</h2>
        <button class="btn btn-primary" @onclick="CreateNew">
            <i class="bi bi-plus-circle"></i> + Νέα Κατηγορία
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    @if (isLoading)
                    {
                        <p><em>Φόρτωση δεδομένων...</em></p>
                    }
                    else if (!conditions.Any())
                    {
                        <p>Δεν υπάρχουν καταχωρημένες μαθησιακές δυσκολίες.</p>
                    }
                    else
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Όνομα</th>
                                    <th>Περιγραφή</th>
                                    <th>Κατάσταση</th>
                                    <th>Ενέργειες</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var condition in conditions)
                                {
                                    <tr>
                                        <td><strong>@condition.Name</strong></td>
                                        <td>@condition.Description</td>
                                        <td>
                                            @if (condition.IsActive)
                                            {
                                                <span class="badge bg-success">Ενεργό</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Ανενεργό</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditCondition(condition)">Επεξεργασία</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCondition(condition.Id)">Διαγραφή</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-5">
            @if (showForm)
            {
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white">
                        @(currentCondition.Id == Guid.Empty ? "Νέα Κατηγορία" : "Επεξεργασία Κατηγορίας")
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Όνομα (π.χ. ΔΕΠΥ)</label>
                            <input type="text" class="form-control" @bind="currentCondition.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Σύντομη Περιγραφή</label>
                            <textarea class="form-control" rows="2" @bind="currentCondition.Description"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-primary fw-bold">Οδηγίες προς το AI (Prompt)</label>
                            <textarea class="form-control" rows="6" @bind="currentCondition.AiPromptInstruction"
                                      placeholder="Γράψε εδώ τις παιδαγωγικές οδηγίες για το πώς πρέπει να απαντάει το Gemini..."></textarea>
                            <small class="text-muted">Αυτό το κείμενο το διαβάζει το AI, όχι οι χρήστες.</small>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="isActiveCheck" @bind="currentCondition.IsActive">
                            <label class="form-check-label" for="isActiveCheck">
                                Ενεργό (Ορατό στους καθηγητές)
                            </label>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button class="btn btn-secondary me-2" @onclick="CancelEdit">Ακύρωση</button>
                            <button class="btn btn-success" @onclick="SaveCondition" disabled="@isSaving">
                                @(isSaving ? "Αποθήκευση..." : "Αποθήκευση")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<LearningConditionDto> conditions = new();
    private LearningConditionDto currentCondition = new();

    private bool isLoading = true;
    private bool showForm = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadConditions();
    }

    private async Task LoadConditions()
    {
        isLoading = true;
        errorMessage = string.Empty;
        try
        {
            conditions = await Http.GetFromJsonAsync<List<LearningConditionDto>>("api/learningconditions") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = "Σφάλμα κατά τη φόρτωση των δεδομένων.";
        }
        isLoading = false;
    }

    private void CreateNew()
    {
        currentCondition = new LearningConditionDto { IsActive = true };
        showForm = true;
        errorMessage = string.Empty;
    }

    private void EditCondition(LearningConditionDto condition)
    {
        // Κάνουμε ένα αντίγραφο για να μην αλλάζει απευθείας στον πίνακα πριν πατήσουμε Αποθήκευση
        currentCondition = new LearningConditionDto
        {
            Id = condition.Id,
            Name = condition.Name,
            Description = condition.Description,
            AiPromptInstruction = condition.AiPromptInstruction,
            IsActive = condition.IsActive
        };
        showForm = true;
        errorMessage = string.Empty;
    }

    private void CancelEdit()
    {
        showForm = false;
        currentCondition = new();
        errorMessage = string.Empty;
    }

    private async Task SaveCondition()
    {
        if (string.IsNullOrWhiteSpace(currentCondition.Name))
        {
            errorMessage = "Το όνομα είναι υποχρεωτικό.";
            return;
        }

        isSaving = true;
        errorMessage = string.Empty;

        HttpResponseMessage response;

        if (currentCondition.Id == Guid.Empty)
        {
            // Δημιουργία νέου (POST)
            response = await Http.PostAsJsonAsync("api/learningconditions", currentCondition);
        }
        else
        {
            // Ενημέρωση υπάρχοντος (PUT)
            response = await Http.PutAsJsonAsync($"api/learningconditions/{currentCondition.Id}", currentCondition);
        }

        if (response.IsSuccessStatusCode)
        {
            await LoadConditions();
            showForm = false;
        }
        else
        {
            errorMessage = "Υπήρξε ένα πρόβλημα κατά την αποθήκευση.";
        }

        isSaving = false;
    }

    private async Task DeleteCondition(Guid id)
    {
        errorMessage = string.Empty;
        var response = await Http.DeleteAsync($"api/learningconditions/{id}");

        if (response.IsSuccessStatusCode)
        {
            await LoadConditions();
        }
        else
        {
            // Αν το API γυρίσει το BadRequest που φτιάξαμε (επειδή υπάρχουν εξαρτήσεις)
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }
}