<div class="top-row ps-3 navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">🧠 Neurabrain</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column mt-3">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="me-2">📊</span> Dashboard
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin, SuperAdmin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/users">
                        <span class="bi bi-people" aria-hidden="true"></span> Χρήστες
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/organizations">
                        <span class="bi bi-buildings" aria-hidden="true"></span> Οργανισμοί
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/learning-conditions">
                        <span class="bi bi-book-half" aria-hidden="true"></span> Μαθησιακές Δυσκολίες
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/subscriptions">
                        <span class="bi bi-credit-card" aria-hidden="true"></span> Συνδρομές
                    </NavLink>
                </div>
            </Authorized> 
        </AuthorizeView>

        <AuthorizeView Roles="SuperAdmin">
            <Authorized>
                <hr class="text-white-50 mx-3" />
                <div class="nav-item px-3">
                    <NavLink class="nav-link text-warning" href="admin/system-settings">
                        <span class="me-2">⚙️</span> System Settings
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

    </nav>
    <footer class="mt-auto px-3 py-2 text-muted">
        <small>v0.6.0-alpha</small> <br />
        <small>&copy; 2026 Neurabrain. All rights reserved.</small>
    </footer>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}